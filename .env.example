# Census API key — required for ACS data sourcing (source-state-metrics.ts).
# Without this, Census API returns HTTP 302 and all ACS requests fail.
# Free key signup: https://api.census.gov/data/key_signup.html
CENSUS_API_KEY=ab25fbd5edd87e70d4c70f88bb31696313377106

# Admin console (/admin/*). Required for production (e.g. npm run start).
# On npm run dev only: omit both to skip admin login locally.
# ADMIN_PUBLISH_PASSWORD=choose-a-strong-password
# ADMIN_PUBLISH_TOKEN=long-random-secret-same-as-session-cookie-value

# Optional: analytics (no-op if unset)
# Google Analytics 4 measurement ID (format: G-XXXXXXXXXX)
NEXT_PUBLIC_GA4_ID=
# Microsoft Clarity project ID (format: abc123xyz)
NEXT_PUBLIC_CLARITY_ID=
